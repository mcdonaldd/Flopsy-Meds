# Supabase project credentials (Dashboard → Project Settings → API)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Anthropic API key — read only by the local extraction server, never sent to the browser.
# Only needed if you use the document intake feature (npm run server).
ANTHROPIC_API_KEY=sk-ant-...
